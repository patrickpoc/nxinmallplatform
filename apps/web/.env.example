# Supabase: DATABASE_URL = pooler (6543 + pgbouncer). DIRECT_URL = conexão direta 5432 (ver painel do Supabase).
# Local: os dois podem ser o mesmo valor.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nxinmall?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/nxinmall?schema=public"

AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Opcional: proxy /api/v1/* para apps/api em dev. Deixe vazio na Vercel (web-only).
API_PROXY_TARGET="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional: POST /api/catalog/revalidate?secret=... after db:seed:reviews (set same value in CATALOG_REVALIDATE_URL for seed)
CATALOG_REVALIDATE_SECRET=""
RESEND_API_KEY=""

# Supabase Storage (fair vendor image uploads: Pix QR, product description images)
# Create a public bucket named `fair-assets` in Supabase Storage.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
