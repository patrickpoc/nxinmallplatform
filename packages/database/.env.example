# URL usada pelo app em runtime. No Supabase, use a string com POOLER (Transaction mode), ex. porta 6543.
# Documentação: https://supabase.com/docs/guides/database/connecting-to-postgres
# Runtime (Vercel/serverless): pooler 6543 + pgbouncer. Avoid connection_limit=1 — it serializes parallel SSR queries.
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL direta (sessão / migrações). No Supabase: "Connection string" URI na porta 5432 (sem pooler).
# Em desenvolvimento local sem pooler, pode ser IGUAL ao DATABASE_URL.
DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# After `pnpm db:seed:reviews` in production, bust Next cache:
# CATALOG_REVALIDATE_URL="https://your-app.vercel.app/api/catalog/revalidate?secret=YOUR_SECRET"
# (set matching CATALOG_REVALIDATE_SECRET on Vercel)

# After `pnpm db:seed`: admin `admin@nxinmall.local` / `admin`; demo seller `demo-seller@nxinmall.local` / `demo`.
# Seed also fills up to 6 ACTIVE demo products per category (random picsum image, price, stock) for catalog/QA — re-run seed to top up missing slots.
