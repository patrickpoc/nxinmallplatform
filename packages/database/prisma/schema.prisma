// NxinMall — single PostgreSQL schema for NextAuth + domain models.
// NextAuth Account/Session/VerificationToken live alongside domain User
// (passwordHash + role on User for credentials + marketplace RBAC).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  /** Pooled URL (Supabase pooler / PgBouncer) — use em runtime serverless (Vercel). */
  url       = env("DATABASE_URL")
  /** URL direta (porta 5432) — obrigatória para `prisma migrate` com Supabase. */
  directUrl = env("DIRECT_URL")
}

// --- NextAuth (Auth.js) + domain User merge ---
model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  role               UserRole  @default(BUYER)
  status             UserStatus @default(ACTIVE)
  languagePreference String    @default("en")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  company       Company?
  savedSearches SavedSearch[]
  notifications Notification[]
  messagesSent  Message[]              @relation("MessageSender")
  threadLinks   MessageThreadParticipant[]
  reviewsGiven  Review[]               @relation("ReviewReviewer")
  reviewsRecv   Review[]               @relation("ReviewReviewee")
  disputesRaised Dispute[]
  auditLogs     AuditLog[]
  buyerRfqs     RFQ[]                  @relation("RfqBuyer")
  sellerRfqs    RFQResponse[]          @relation("RfqResponseSeller")
  buyerOrders   Order[]                @relation("OrderBuyer")
  sellerOrders  Order[]                @relation("OrderSeller")
  products      Product[]              @relation("ProductSeller")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Core entities ---
model Company {
  id                  String                   @id @default(cuid())
  name                String
  legalName           String?
  cnpj                String?
  registrationNumber  String?
  country             String
  type                String
  verificationStatus  CompanyVerificationStatus @default(PENDING)
  verificationTier    VerificationTier         @default(UNVERIFIED)
  logoUrl             String?
  userId              String                   @unique
  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses           Address[]
  documents           Document[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
}

model Address {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  street     String
  city       String
  state      String?
  country    String
  postalCode String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Document {
  id        String         @id @default(cuid())
  companyId String
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type      DocumentType
  url       String
  status    DocumentStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// --- Catalog ---
model Category {
  id       String     @id @default(cuid())
  name     Json // { en, pt, zh }
  slug     String     @unique
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  iconUrl  String?
  products Product[]
  rfqs     RFQ[]
  priceSignals PriceSignal[]
}

model Product {
  id          String        @id @default(cuid())
  sellerId    String
  seller      User          @relation("ProductSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  name        Json
  description Json?
  status      ProductStatus @default(DRAFT)
  /** Home carousel: sponsored listings (paid placement). */
  isSponsored       Boolean   @default(false)
  sponsoredSortOrder Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  variants     ProductVariant[]
  images       ProductImage[]
  docs         ProductDoc[]
  matches      ProductMatch[]
  reviews      ProductReview[]

  @@index([status, createdAt])
  @@index([status, isSponsored, sponsoredSortOrder])
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  authorName String
  rating     Int
  body       String   @db.Text
  locale     String   @default("en")
  createdAt  DateTime @default(now())

  @@index([productId])
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku         String
  priceUsd    Decimal  @db.Decimal(20, 6)
  /** Price in the currency chosen by the lister (front-end converts for display). */
  priceAmount Decimal  @db.Decimal(20, 6) @default(0)
  priceCurrency CurrencyCode @default(USD)
  minOrderQty Int
  unit        UnitType
  stockQty    Int
  attributes  Json?
  orderItems  OrderItem[]

  @@unique([productId, sku])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
}

model ProductDoc {
  id        String          @id @default(cuid())
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      ProductDocType
  url       String
  name      String
}

// --- Trade ---
model RFQ {
  id              String    @id @default(cuid())
  buyerId         String
  buyer           User      @relation("RfqBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  title           String
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id])
  description     String    @db.Text
  quantity        Decimal   @db.Decimal(20, 6)
  unit            UnitType
  targetPriceUsd  Decimal?  @db.Decimal(20, 6)
  deadline        DateTime
  status          RFQStatus @default(OPEN)
  attachments     Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  responses   RFQResponse[]
  matches     ProductMatch[]
  threads     MessageThread[]
  orders      Order[]
}

model RFQResponse {
  id           String            @id @default(cuid())
  rfqId        String
  rfq          RFQ               @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  sellerId     String
  seller       User              @relation("RfqResponseSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  priceUsd     Decimal           @db.Decimal(20, 6)
  leadTimeDays Int
  message      String?           @db.Text
  attachments  Json?
  status       RFQResponseStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Order {
  id        String      @id @default(cuid())
  buyerId   String
  buyer     User        @relation("OrderBuyer", fields: [buyerId], references: [id])
  sellerId  String
  seller    User        @relation("OrderSeller", fields: [sellerId], references: [id])
  status    OrderStatus @default(PENDING)
  rfqId     String?
  rfq       RFQ?        @relation(fields: [rfqId], references: [id])
  incoterm  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  items       OrderItem[]
  documents   OrderDocument[]
  payments    Payment[]
  shipments   Shipment[]
  threads     MessageThread[]
  reviews     Review[]
  disputes    Dispute[]
}

model OrderItem {
  id           String          @id @default(cuid())
  orderId      String
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId    String
  variant      ProductVariant  @relation(fields: [variantId], references: [id])
  qty          Decimal         @db.Decimal(20, 6)
  unitPriceUsd Decimal         @db.Decimal(20, 6)
  totalUsd     Decimal         @db.Decimal(20, 6)
}

model OrderDocument {
  id      String            @id @default(cuid())
  orderId String
  order   Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type    OrderDocumentType
  url     String
}

model Payment {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount    Decimal        @db.Decimal(20, 6)
  currency  String
  gateway   PaymentGateway
  status    PaymentStatus  @default(PENDING)
  reference String?
  metadata  Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Shipment {
  id                 String          @id @default(cuid())
  orderId            String
  order              Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier            String?
  trackingNumber     String?
  status             ShipmentStatus  @default(PENDING)
  estimatedDelivery  DateTime?
  actualDelivery     DateTime?
  incoterm           String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

// --- Intelligence ---
model SavedSearch {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filters      Json
  alertEnabled Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model ProductMatch {
  id        String   @id @default(cuid())
  rfqId     String
  rfq       RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  score     Float
  reasons   Json?
  createdAt DateTime @default(now())

  @@unique([rfqId, productId])
}

model PriceSignal {
  id          String   @id @default(cuid())
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  regionCode  String
  priceUsd    Decimal  @db.Decimal(20, 6)
  unit        UnitType
  source      String
  recordedAt  DateTime @default(now())
}

// --- Messaging ---
model MessageThread {
  id        String   @id @default(cuid())
  subject   String?
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id])
  rfqId     String?
  rfq       RFQ?     @relation(fields: [rfqId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants MessageThreadParticipant[]
  messages     Message[]
}

model MessageThreadParticipant {
  threadId String
  userId   String
  thread   MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
}

model Message {
  id           String   @id @default(cuid())
  threadId     String
  thread       MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId     String
  sender       User     @relation("MessageSender", fields: [senderId], references: [id])
  body         String   @db.Text
  attachments  Json?
  readAt       DateTime?
  createdAt    DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String   @db.Text
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
}

// --- Trust & ops ---
model Review {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User     @relation("ReviewReviewer", fields: [reviewerId], references: [id])
  revieweeId String
  reviewee   User     @relation("ReviewReviewee", fields: [revieweeId], references: [id])
  rating     Int
  body       String?  @db.Text
  response   String?  @db.Text
  createdAt  DateTime @default(now())
  editedUntil DateTime?
}

model Dispute {
  id          String        @id @default(cuid())
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  raisedById  String
  raisedBy    User          @relation(fields: [raisedById], references: [id])
  reason      String        @db.Text
  status      DisputeStatus @default(OPEN)
  resolution  String?       @db.Text
  adminNotes  String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

// --- Enums ---
enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum CompanyVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationTier {
  UNVERIFIED
  BASIC
  VERIFIED
  PREMIUM
}

enum DocumentType {
  TRADE_LICENSE
  TAX_ID
  CERTIFICATE
  OTHER
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  PAUSED
  REJECTED
}

enum ProductDocType {
  CERTIFICATE
  SPEC_SHEET
  MSDS
  OTHER
}

enum UnitType {
  KG
  TON
  UNIT
  BOX
  PALLET
}

enum CurrencyCode {
  USD
  BRL
}

enum RFQStatus {
  OPEN
  RECEIVING_QUOTES
  UNDER_REVIEW
  CLOSED
  CONVERTED
}

enum RFQResponseStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  DISPUTED
}

enum OrderDocumentType {
  INVOICE
  PACKING_LIST
  COO
  BL
  OTHER
}

enum PaymentGateway {
  LAKALA
  STRIPE
  PAGSEGURO
  WIRE
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum ShipmentStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  EXCEPTION
}

enum DisputeStatus {
  OPEN
  SELLER_RESPONSE
  ESCALATED
  RESOLVED
  CLOSED
}
